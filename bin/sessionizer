#!/usr/bin/dash

TARGET_DIR=""
OPERATION=""

switch_to_project() {
    local target_dir="$1"
    local session_name="$(basename $target_dir)"
    cd $target_dir
    exec nvim
}

case "$1" in
git) exec lazygit ;;
gitweb)
    cd "$PROJDIR"
    TARGET_DIR="$(fd --format="{//}" -Hgtd .git | fuzzel --dmenu --placeholder="Choose project")"
    [ -z "$TARGET_DIR" ] && exit 0 || TARGET_DIR="$PROJDIR/$TARGET_DIR"
    [ -d "$TARGET_DIR" ] || exit 1
    cd "$TARGET_DIR"
    url="$(git config --get remote.origin.url)"
    echo "$url"
    [ -z "$url" ] && {
        notify-send "Failed to find git url for \"$WORKING_DIRECTORY\""
        exit 0
    }
    default_browser="$(xdg-mime query default x-scheme-handler/https)"
    [ -z "$default_browser" ] && {
        notify-send "Failed to find a default browser"
        exit 0
    }

    hyprctl dispatch focuswindow "class:${default_browser%%.*}"
    exec xdg-open "$url"
    ;;
projects)
    cd "$PROJDIR"
    TARGET_DIR="$(fd --format="{//}" -Hgtd .git | fuzzel --dmenu --placeholder="Choose project")"
    [ -z "$TARGET_DIR" ] && exit 0 || TARGET_DIR="$PROJDIR/$TARGET_DIR"
    [ -d "$TARGET_DIR" ] || exit 1

    exec footclient -D "$TARGET_DIR" -T nvim -a nvim nvim
    ;;
home_session)
    TARGET_DIR="$HOME"
    exec footclient -D "$TARGET_DIR" -T nvim -a nvim nvim
    ;;
esac
