#!/usr/bin/dash

# NOTE: Running this script without hyprpaper running will launch hyprpaper! nice!
#
# See $DOTDIR/dotconfig/hypr/hyprpaper.conf. I set the wallpaper path with an env var

wallpaper_directory="${WALLPAPER_DIRECTORY:-$PROJDIR/muur_papier}"
requested_wallpaper="$DEFAULT_WALLPAPER"

while [ $# -gt 0 ]; do
    case "$1" in
    --set | -s)
        echo "requested_wallpaper=$2"
        set_requested=true
        requested_wallpaper="$2"
        shift 2 || exit 1
        ;;
    --set-last | -S)
        echo "set_last_used=true"
        set_last_used=true
        shift
        ;;
    --reverse | -r)
        echo "reverse=true"
        reverse=true
        shift
        ;;
    --random | -R)
        echo "random=true"
        random=true
        shift
        ;;
    --force | -f)
        echo "force=true"
        force=true
        shift
        ;;
    *)
        echo "Usage: $0 [--help|-h] [--set|-s <wallpaper>] [--reverse|-r] [--set-last|-S] [--random|-R] [--force|-f]"
        echo
        echo "	--help              -h | display this message."
        echo "	--set               -s | Specify a wallpaper to set."
        echo "	--set-last          -S | Trys to set the wallpaper to the last set wallpaper. On failure default behaviour occurs."
        echo "	--reverse           -r | Reverse the order of the wallpaper cycling."
        echo "	--random            -R | Choose a random wallpaper."
        echo "	--force             -f | Tell hyprpaper to set the wallpaper even if it is already loaded."
        exit 0
        ;;
    esac
done

STATE_FILE=$XDG_CACHE_HOME/lastwallpaper
[ -r "$STATE_FILE" ] && STATE="$(cat $STATE_FILE)" || STATE=
current_image="${STATE#*::}"
current_image_index="${STATE%%::*}"

set_requested() {
    local req_wall="$1"
    [ -f "$req_wall" ] && next_image="$req_wall" || next_image="$(fd -1atfile "$(basename "$req_wall")" "$wallpaper_directory")"
    next_image_index="$(fd -atf -ejxl . "$wallpaper_directory" | rg -nFm1 "$next_image" | cut -d: -f1)"
    next_image_index="${next_image_index%%:*}"
    next_image_index="${next_image_index:-1}"
    next_image_index="$((next_image_index - 1))"
}

set_random() {
    local random="$1"
    local reverse="$2"

    local images="$(fd -atf -ejxl . "$wallpaper_directory")"
    local num_images="$(echo "$images" | wc -l)"

    [ $num_images -eq 0 ] && { echo "No images found." && exit 1; }

    if [ -n "$random" ]; then
        next_image_index=$(($(date +%N) % num_images))
    elif [ -z "$current_image_index" ]; then
        next_image_index=0
    elif [ -n "$reverse" ]; then
        next_image_index=$(((current_image_index + num_images - 1) % num_images))
    else
        next_image_index=$(((current_image_index + 1) % num_images))
    fi

    next_image="$(echo "$images" | sed -n "$((next_image_index + 1))"p)"
}

# Set last used if requested
[ -z "$wallpaper_set" ] && [ -n "$current_image" ] && [ -n "$set_last_used" ] && {
    wallpaper_set=true
    requested_wallpaper="$current_image"
    set_requested "$requested_wallpaper"
}

# Otherwise fallback to requested
[ -z "$wallpaper_set" ] && [ -n "$set_requested" ] && {
    wallpaper_set=true
    set_requested "$requested_wallpaper"
}

# Otherwise fallback to random
[ -z "$wallpaper_set" ] && {
    wallpaper_set=true
    set_random "$random" "$reverse"
}

[ -n "$force" ] || [ "$current_image" != "$next_image" ] && {
    printf "$next_image_index::$next_image" >"$STATE_FILE"
    pidof -q /usr/bin/hyprpaper && {
        hyprctl hyprpaper wallpaper ",$next_image,"
    } || {
        HYPRPAPER_NEXT_IMAGE="$next_image" hyprpaper &
    }
}
