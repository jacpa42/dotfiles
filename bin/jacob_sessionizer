#!/usr/bin/dash

TARGET_DIR=""
OPERATION=""

case "$1" in
lazygit)
    cd "$PROJDIR"
    TARGET_DIR="$(fd --format="{//}" -Hgtd .git | fuzzel --dmenu --placeholder="Choose project")"
    [ -z "$TARGET_DIR" ] && exit 0 || TARGET_DIR="$PROJDIR/$TARGET_DIR"
    [ -d "$TARGET_DIR" ] || exit 1

    exec footclient -D "$TARGET_DIR" -T lazygit -a lazygit sh -c "lazygit"
    ;;
gitweb)
    cd "$PROJDIR"
    TARGET_DIR="$(fd --format="{//}" -Hgtd .git | fuzzel --dmenu --placeholder="Choose project")"
    [ -z "$TARGET_DIR" ] && exit 0 || TARGET_DIR="$PROJDIR/$TARGET_DIR"
    [ -d "$TARGET_DIR" ] || exit 1

    cd "$TARGET_DIR"
    url="$(git config --get remote.origin.url)"
    echo "$url"
    [ -z "$url" ] && {
        notify-send "Failed to find git url for \"$WORKING_DIRECTORY\""
        exit 0
    }
    default_browser="$(xdg-mime query default x-scheme-handler/https)"
    [ -z "$default_browser" ] && {
        notify-send "Failed to find a default browser"
        exit 0
    }

    jacob_focuswindowclass "${default_browser%%.*}"
    exec xdg-open "$url"
    ;;
projects)
    cd "$PROJDIR"
    TARGET_DIR="$(fd --format="{//}" -Hgtd .git | fuzzel --dmenu --placeholder="Choose project")"
    TITLE="$(basename "$TARGET_DIR")"
    [ -z "$TARGET_DIR" ] && exit 0 || TARGET_DIR="$PROJDIR/$TARGET_DIR"
    [ -d "$TARGET_DIR" ] || exit 1

    exec footclient -D "$TARGET_DIR" -T "$TITLE" -a nvim sh -c "nvim; $SHELL"
    ;;
esac
