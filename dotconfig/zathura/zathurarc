set font "JetBrains Mono Nerd Font 24"

set default-bg                  "#000000"
set default-fg                  "#c1c1c1"
set statusbar-fg                "#000000"
set statusbar-bg                "#222222"
set inputbar-bg                 "#000000"
set inputbar-fg                 "#c1c1c1"
set notification-bg             "#000000"
set notification-fg             "#c1c1c1"
set notification-error-bg       "#000000"
set notification-error-fg       "#5f8787"
set notification-warning-bg     "#000000"
set notification-warning-fg     "#5f8787"
set highlight-color             "#974b46"
set highlight-active-color      "#888888"
set completion-bg               "#121212"
set completion-fg               "#888888"
set completion-highlight-fg     "#c1c1c1"
set completion-highlight-bg     "#888888"
set recolor-lightcolor          "#000000"
set recolor-darkcolor           "#999999"
set recolor                     "false"
set recolor-keephue             "false"

set statusbar-h-padding 0
set statusbar-v-padding 0

# Defines if the search results should be cleared on abort.
# • Value type: Boolean
set abort-clear-search true

# Defines which auto adjustment mode should be used if a document is loaded.  Possible options are "best-fit" and "width".
# • Value type: String
set adjust-open width

# Defines if the number of pages per row should be honored when advancing a page.
# • Value type: Boolean
set advance-pages-per-row false

# Tells zathura whether to save document history at each page change or only when closing a document.
# • Value type: Boolean
set continuous-hist-save false

# Defines the database backend to use for bookmarks and input history. Possible values are "sqlite" and "null". If "null" is used, book‐
# marks and input history will not be stored.
# • Value type: String
set database null

# Defines whether zathura's window should be raised when receiving certain commands via D-Bus.
# • Value type: Boolean
set dbus-raise-window true

# En/Disables the D-Bus service. If the services is disabled, SyncTeX forward synchronization is not available.
# • Value type: Boolean
set dbus-service false

# Defines whether double or single click on a link should trigger follow.
# • Value type: Boolean
set double-click-follow true

# Defines the file monitor backend used to check for changes in files. Possible values are "glib", "signal" (if signal handling is  sup‐
# ported), and "noop". The "noop" file monitor does not trigger reloads.
# • Value type: String
set filemonitor noop

# Defines the column in which the first page will be displayed. This
# setting is stored separately for every value of pages-per-row according
# to the following pattern <1 page per row>:[<2 pages per row>[: ...]].
# The last value in the list will be used for all other number of pages
# per row if not set explicitly. page in dual-page layout in the first
# column, and for layouts with more columns the first page would be put in the 3rd column.
# • Value type: String
set first-page-column "1"

# Defines the color that is used for text when highlighting parts of the document (e.g.: number for links).
# • Value type: String
set highlight-fg rgb(29,32,47)

# Defines the modifier that needs to be pressed together with the left mouse  button  to  draw  the  highlighter.  Possible  values  are
# "shift", "ctrl" and "alt".
# • Value type: String
set highlighter-modifier shift

# En/Disables incremental search (search while typing).
# • Value type: Boolean
set incremental-search true

# Define the background color of the selected element in index mode.
# • Value type: String
set index-active-bg rgb(126,156,216)

# Defines the foreground color of the selected element in index mode.
# • Value type: String
set index-active-fg rgb(29,32,47)

# Define the background color of the index mode.
# • Value type: String
set index-bg rgb(29,32,47)

# Defines the foreground color of the index mode.
# • Value type: String
set index-fg rgb(225,238,217)

# Maximum number of positions to remember in the jumplist.
# • Value type: Integer
set jumplist-size 2000

# En/Disables aligning to the left internal link targets, for example from the index.
# • Value type: Boolean
set link-hadjust false

# En/Disables the ability of changing zoom when following links.
# • Value type: Boolean
set link-zoom true

# Dis/Enables the highlighting of search results.
# • Value type: Boolean
set nohlsearch false

# Always open documents on the first page. If disabled, zathura will jump to the last remembered position.
# • Value type: Boolean
set open-first-page false

# Defines  the maximum number of pages that could be kept in the page cache. When the cache is full and a new page that isn't cached be‐
# comes visible, the least recently viewed page in the cache will be evicted to make room for the new one.  Large values for this  vari‐
# able are NOT recommended, because this will lead to consuming a significant portion of the system memory.
# • Value type: Integer
set page-cache-size 15

# Vertical page padding defines the vertical gap in pixels between each rendered page.
# • Value type: Integer
set page-v-padding 1

# Horizontal page padding defines the horizontal gap in pixels between each rendered page.
# • Value type: Integer
set page-h-padding 1

# Defines whether pages in multi-column view should start from the right side.
# • Value type: Boolean
set page-right-to-left false

# Defines  the maximum size in pixels of the thumbnail that could be kept in the thumbnail cache per page. The thumbnail is scaled for a
# quick preview during zooming before the page is rendered. When the page is rendered, the result is saved as the thumbnail only if  the
# size is no more than this value. A larger value increases quality but introduces longer delay in zooming and uses more system memory.
# • Value type: Integer
set page-thumbnail-size (4M)

# Defines the number of pages that are rendered next to each other in a row.
# • Value type: Integer
set pages-per-row 1

# En/Disables adjusting lightness when recoloring.
# • Value type: Boolean
set recolor-adjust-lightness true

# Defines if original image colors should be kept while recoloring.
# • Value type: Boolean
set recolor-reverse-video false

# Defines if the "Loading..." text should be displayed if a page is rendered.
# • Value type: Boolean
set render-loading true

# Defines the background color that is used for the "Loading..." text.
# • Value type: String
set render-loading-bg rgb(220,215,186)

# Defines the foreground color that is used for the "Loading..." text.
# • Value type: String
set render-loading-fg rgb(9,6,24)

# Defines the proportion of the current viewing area that should be visible after scrolling a full page.
# • Value type: Float
set scroll-full-overlap 0

# Defines the horizontal step size of scrolling by calling the scroll command once
# • Value type: Float
set scroll-hstep -1

# Defines the step size of scrolling by calling the scroll command once
# • Value type: Float
set scroll-step 40

# Defines if scrolling by half or full pages stops at page boundaries.
# • Value type: Boolean
set scroll-page-aware false

# Defines if the last/first page should be wrapped
# • Value type: Boolean
set scroll-wrap false

# En/Disables horizontally centered search results.
# • Value type: Boolean
set search-hadjust true

# Defines the X clipboard into which mouse-selected data will be written.  When it is "clipboard", selected data will be written to the
# CLIPBOARD clipboard, and can be pasted using the Ctrl+v key combination.  When it is "primary", selected data will be written  to  the
# PRIMARY clipboard, and can be pasted using the middle mouse button, or the Shift-Insert key combination. The value "false" can be used
# to disable copying to the clipboard.
# • Value type: String
set selection-clipboard clipboard

# Defines if a notification should be displayed after selecting text.
# • Value type: Boolean
set selection-notification true

# Defines the background color when displaying additional information for signatures with errors.
# • Value type: String
set signature-error-color rgba(195,64,67,0.9)

# Defines the background color when displaying additional information for valid signatures.
# • Value type: String
set signature-success-color rgba(149,127,184,0.9)

# Defines the background color when displaying additional information for signatures with warnings.
# • Value type: String
set signature-warning-color rgba(192,163,110,0.9)

# Defines if the directories should be displayed in completion.
# • Value type: Boolean
set show-directories true

# Defines if hidden files and directories should be displayed in completion.
# • Value type: Boolean
set show-hidden false

# Defines  the number of recent files that should be displayed in completion.  If the value is negative, no upper bounds are applied. If
# the value is 0, no recent files are shown.
# • Value type: Integer
set show-recent 10

# Defines whether additional information on signatures embedded in documents should be displayed.
# • value type: Boolean
set show-signature-information false

# Use basename of the file in the statusbar.
# • Value type: Boolean
set statusbar-basename false

# Display a short version of the file path, which replaces $HOME with ~, in the statusbar.
# • Value type: Boolean
set statusbar-home-tilde true

# Display (current page / total pages) as a percent in the statusbar.
# • Value type: Boolean
set statusbar-page-percent false

# En/Disables SyncTeX backward synchronization support.
# • Value type: Boolean
set synctex true

# Defines the modifier that needs to be pressed together with the left mouse button to trigger  the  SyncTeX  backward  synchronization.
# Possible values are "shift", "ctrl" and "alt".
# • Value type: String
set synctex-edit-modifier ctrl

# Defines the command executed for SyncTeX backward synchronization.
# • Value type: String
set synctex-editor-command value:

# • Value type: Boolean
set vertical-center false

# Defines whether the window document should be updated based on the first page of a dcument.
# • Value type: Boolean
set window-icon-document false

# Use basename of the file in the window title.
# • Value type: Boolean
set window-title-basename true

# Display a short version of the file path, which replaces $HOME with ~, in the window title.
# • Value type: Boolean
set window-title-home-tilde false

# Display the page number in the window title.
# • Value type: Boolean
set window-title-page false

# En/Disables horizontally centered zooming.
# • Value type: Boolean
set zoom-center false

# Defines the maximum percentage that the zoom level can be.
# • Value type: Integer
set zoom-max 1000

# Defines the minimum percentage that the zoom level can be.
# • Value type: Integer
set zoom-min 10

# Defines the amount of percent that is zoomed in or out on each command.
# • Value type: Integer
set zoom-step 10
