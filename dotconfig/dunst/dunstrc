[global]
font = "JetBrainsMono Nerd Font 11"
frame_color = "#000000"
separator_color = frame
highlight = "#000000"
follow = keyboard
offset = (0, 0)

[urgency_low]
background = "#000000"
foreground = "#c1c1c1"

[urgency_normal]
background = "#000000"
foreground = "#5f8787"

[urgency_critical]
background = "#000000"
foreground = "#974b46"
